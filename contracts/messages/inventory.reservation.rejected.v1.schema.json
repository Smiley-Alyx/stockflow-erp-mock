{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "inventory.reservation.rejected.v1.schema.json",
  "title": "Inventory reservation rejected v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reservation_id",
    "order_id",
    "sku",
    "quantity",
    "reason"
  ],
  "properties": {
    "reservation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "order_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "sku": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "quantity": {
      "type": "integer",
      "minimum": 1
    },
    "reason": {
      "type": "string",
      "enum": [
        "INSUFFICIENT_STOCK",
        "INVALID_REQUEST",
        "FAILURE_MODE"
      ]
    },
    "details": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "examples": [
    {
      "reservation_id": "res-10001",
      "order_id": "ord-10001",
      "sku": "sku-red-mug",
      "quantity": 200,
      "reason": "INSUFFICIENT_STOCK",
      "details": "Requested quantity exceeds available stock."
    }
  ]
}
