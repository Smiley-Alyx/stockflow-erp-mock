{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "inventory.reservation.release_requested.v1.schema.json",
  "title": "Inventory reservation release requested v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reservation_id"
  ],
  "properties": {
    "reservation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "reason": {
      "type": "string",
      "maxLength": 255
    }
  },
  "examples": [
    {
      "reservation_id": "res-10001",
      "reason": "order_cancelled"
    }
  ]
}
